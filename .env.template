# ==============================================================================
# CONFIGURAÇÃO DE AMBIENTE - PROJETO ENEM 2026 (TEMPLATE OFICIAL)
# ==============================================================================
# Instruções:
# 1. Copie este arquivo para um novo arquivo chamado .env
# 2. Preencha as variáveis abaixo com suas credenciais reais.
# 3. Nunca envie o arquivo .env real para o controle de versão (Git).
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. BANCO DE DADOS (Neon PostgreSQL)
# ------------------------------------------------------------------------------
# IMPORTANTE: Use a conexão DIRETA (sem -pooler) para desenvolvimento local 
# a fim de evitar erros de permissão P1010 no Prisma.
# Exemplo: postgresql://user:password@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="Sua_URL_PostgreSQL_Aqui"

# ------------------------------------------------------------------------------
# 2. AUTENTICAÇÃO (NextAuth.js v5)
# ------------------------------------------------------------------------------
# Gere um segredo aleatório com: openssl rand -base64 32
AUTH_SECRET="Seu_Segredo_Auth_Aqui"

# URLs de Redirecionamento
NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"

# Google Auth (Opcional - Ative no Google Cloud Console)
GOOGLE_CLIENT_ID="Seu_Google_Client_ID"
GOOGLE_CLIENT_SECRET="Seu_Google_Client_Secret"

# ------------------------------------------------------------------------------
# 3. INTELIGÊNCIA ARTIFICIAL (IA)
# ------------------------------------------------------------------------------
# Chave Primária (High-Speed Llama 3 via Groq)
GROQ_API_KEY="Sua_Groq_API_Key_Aqui"

# Chave de Auditoria/Fallback (Grok via xAI)
GROK_API_KEY="Sua_Grok_API_Key_Aqui"

# Chave Google Gemini (Opcional/Legacy)
GEMINI_API_KEY="Sua_Gemini_API_Key_Aqui"

# ------------------------------------------------------------------------------
# 4. SISTEMA DE E-MAIL (Recuperação de Senha)
# ------------------------------------------------------------------------------
# Configuração SMTP (Recomendado: Gmail com "Senha de App")
EMAIL_USER="seu-email@gmail.com"
EMAIL_PASS="sua-senha-de-app-de-16-digitos"

# API de Envio Alternativa (Resend)
RESEND_API_KEY="re_Sua_Chave_Aqui"

# ------------------------------------------------------------------------------
# 5. MONITORAMENTO E ADMINISTRAÇÃO
# ------------------------------------------------------------------------------
# E-mail do proprietário para liberar funções administrativas no Dashboard
DEV_EMAIL="seu-email-admin@gmail.com"
