# Arquivo de configuração de ambiente para o Projeto ENEM 2026
# Renomeie para .env e preencha com seus dados

# URL do Banco de Dados (PostgreSQL)
# Exemplo (Neon): postgresql://user:password@hostname/dbname?sslmode=require
DATABASE_URL="Sua_URL_PostgreSQL_Aqui"

# Configuração de Autenticação (NextAuth)
# Gere um segredo com: openssl rand -base64 32
AUTH_SECRET="Seu_Segredo_Auth_Aqui"

# Google Auth (Opcional, se usar login Google)
GOOGLE_CLIENT_ID="Seu_Google_Client_ID"
GOOGLE_CLIENT_SECRET="Seu_Google_Client_Secret"

# IA (Google Gemini)
GEMINI_API_KEY="Sua_Gemini_API_Key_Aqui"

# Email do Desenvolvedor (Para liberar o botão de Reset no Dashboard)
DEV_EMAIL="seu-email@gmail.com"
